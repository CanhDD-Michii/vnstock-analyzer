# MySQL (Docker Compose)
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=vnstock
# Cổng map ra host (mặc định 3306)
MYSQL_PORT=3306

# Backend — trong Docker Compose để trống hoặc dùng hostname `mysql` (xem docker-compose.yml).
# Chạy BE ngoài Docker thì trỏ tới localhost:
DATABASE_URL=mysql+pymysql://root:root@127.0.0.1:3306/vnstock?charset=utf8mb4

# CORS — origin trình duyệt (nếu đổi FRONTEND_PORT thì thêm origin tương ứng, ví dụ http://localhost:3001)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Cổng map ra host
BACKEND_PORT=8000
FRONTEND_PORT=3000

# Backend debug SQL echo (true/false)
BACKEND_DEBUG=false

# JWT (bắt buộc production) openssl rand -hex 32
JWT_SECRET=b896f09787253d7902a48e1210317d16d97aa3192ef475ee4f197d212199008d

# OpenAI (tùy chọn — không có vẫn chạy, AI dùng placeholder)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Seed admin + mã FPT demo khi backend khởi động (Docker: true)
SEED_ADMIN_ON_STARTUP=false
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!

# Frontend — URL API mà trình duyệt gọi (host + port map của backend)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Frontend SSR trong Docker — hostname service backend (không dùng cho trình duyệt)
# Khi chạy `next dev` trên máy host, có thể bỏ qua (SSR dùng NEXT_PUBLIC_API_URL).
API_URL=http://backend:8000
